# ──────────────────────────────────────────────────────────────────────
# GameRadar AI — Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────

# ── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# ── Subscriber Hub ────────────────────────────────────────────────────
# Any random string ≥ 32 characters — used to sign HMAC session tokens
HUB_TOKEN_SECRET=change-this-to-any-random-32char-secret

# ── SMTP (required for delivery.py) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=GameRadar AI <you@gmail.com>
# Set SMTP_SSL=true to use SSL on port 465 instead of STARTTLS
# SMTP_SSL=false

# ── Stripe Customer Portal ────────────────────────────────────────────
PORTAL_RETURN_URL=http://localhost:3000/landing.html

# ── Scraping (optional) ───────────────────────────────────────────────
# Riot Games API — free dev key at https://developer.riotgames.com/
# Development key expires every 24 h; production key does not expire.
RIOT_API_KEY=your-riot-api-key-here

# Rotating proxy for China sources (PentaQ, Wanplus)
# Format: http://user:pass@host:port  or  socks5://host:port
# PROXY_URL=

# Wanplus
# WANPLUS_API_KEY=

# ── Scraper tuning ────────────────────────────────────────────────────
RATE_LIMIT_DELAY=2
MAX_CONCURRENT_REQUESTS=5

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
