# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Airtable Configuration (opcional)
AIRTABLE_API_KEY=your-airtable-api-key
AIRTABLE_BASE_ID=your-base-id
AIRTABLE_TABLE_NAME=GameRadar_Players

# Scraper Configuration
RATE_LIMIT_DELAY=2
MAX_CONCURRENT_REQUESTS=5
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Riot Games Official API (Fallback automático cuando scraping falla)
# Obtén tu API key GRATIS en: https://developer.riotgames.com/
# Development Key: Expira cada 24h (perfecto para dev/testing)
# Production Key: No expira (requiere registro de app, gratis)
# Rate Limits: 20 requests/s, 100 requests/2min
RIOT_API_KEY=your-riot-api-key-here

# Logging
LOG_LEVEL=INFO

# OpenAI Configuration (para embeddings semánticos)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Proxy Configuration (opcional - para ninja scraper)
# Opción 1: Bright Data
# BRIGHT_DATA_USERNAME=your-username
# BRIGHT_DATA_PASSWORD=your-password
# BRIGHT_DATA_HOST=brd.superproxy.io
# BRIGHT_DATA_PORT=22225

# Opción 2: ScraperAPI
# SCRAPERAPI_KEY=your-api-key

# Opción 3: Custom Proxies (formato: host:port:user:pass,host2:port2:user2:pass2)
# PROXY_LIST=
