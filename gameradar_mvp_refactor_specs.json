{
  "metadata": {
    "version": "1.0.0",
    "last_updated": "2026-04-16",
    "description": "GameRadar AI - MVP Refactor Specifications for Power BI Dashboard",
    "purpose": "Data model for comparing amateur prospects vs established professionals with regional difficulty adjustments"
  },
  "mechanical_skill_vectors": {
    "description": "Multi-dimensional skill assessment framework for radar charts (Spider Charts)",
    "dimensions": [
      {
        "id": "micro_mechanics",
        "name": "Micro Mechanics",
        "scale": "0-100",
        "weight": 0.20,
        "components": ["APM", "CS/min", "Reaction Time", "Combo Execution"],
        "sources": ["wanplus", "opgg", "riot_api_kr"]
      },
      {
        "id": "macro_awareness",
        "name": "Macro Awareness",
        "scale": "0-100",
        "weight": 0.18,
        "components": ["Map Awareness", "Objective Control", "Rotation Timing"],
        "sources": ["opgg", "riot_api_kr", "dakgg"]
      },
      {
        "id": "consistency",
        "name": "Consistency Score",
        "scale": "0-100",
        "weight": 0.15,
        "components": ["Performance Variance", "Tilt Resistance", "Clutch Factor"],
        "sources": ["tec_india", "riot_api_kr", "opgg"]
      },
      {
        "id": "adaptability",
        "name": "Adaptability",
        "scale": "0-100",
        "weight": 0.12,
        "components": ["Champion Pool Depth", "Meta Adaptation", "Role Flexibility"],
        "sources": ["opgg", "dakgg", "riot_api_kr"]
      },
      {
        "id": "team_synergy",
        "name": "Team Synergy",
        "scale": "0-100",
        "weight": 0.15,
        "components": ["Assist Rate", "Vision Score", "Communication Rating"],
        "sources": ["opgg", "soha_game", "tec_india"]
      },
      {
        "id": "mechanical_ceiling",
        "name": "Mechanical Ceiling",
        "scale": "0-100",
        "weight": 0.20,
        "components": ["Peak Performance", "Outplay Potential", "Skill Expression"],
        "sources": ["wanplus", "riot_api_kr", "loot_bet"]
      }
    ],
    "aggregation_method": "weighted_average",
    "visualization_type": "spider_chart"
  },
  "regional_difficulty_multipliers": {
    "description": "Regional difficulty adjustments for global ranking normalization",
    "formula": "adjusted_score = base_score × regional_multiplier × server_competitiveness",
    "regions": [
