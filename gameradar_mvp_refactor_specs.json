  "power_bi_data_model": {
    "description": "Recommended data model structure for Power BI import",
    "tables": [
      {
        "name": "Players",
        "source": "bronze_raw_data / silver_players",
        "primary_key": "player_id",
        "columns": [
          {"name": "player_id", "type": "Text", "description": "Unique player identifier"},
          {"name": "nickname", "type": "Text", "description": "Player nickname"},
          {"name": "country_code", "type": "Text", "description": "ISO 3166-1 Alpha-2"},
          {"name": "region", "type": "Text", "description": "KR, CN, IN, VN, JP, SEA"},
          {"name": "rank", "type": "Text", "description": "challenger, grandmaster, master, etc."},
          {"name": "team", "type": "Text", "description": "Professional team (null for amateurs)"},
          {"name": "is_professional", "type": "Boolean", "description": "true/false"},
          {"name": "player_archetype", "type": "Text", "description": "From player_archetypes"}
        ]
      },
      {
        "name": "MechanicalSkills",
        "source": "Calculated from stats and advanced_metrics",
        "primary_key": "player_id",
        "columns": [
          {"name": "player_id", "type": "Text"},
          {"name": "micro_mechanics", "type": "Number", "scale": "0-100"},
          {"name": "macro_awareness", "type": "Number", "scale": "0-100"},
          {"name": "consistency", "type": "Number", "scale": "0-100"},
          {"name": "adaptability", "type": "Number", "scale": "0-100"},
          {"name": "team_synergy", "type": "Number", "scale": "0-100"},
          {"name": "mechanical_ceiling", "type": "Number", "scale": "0-100"}
        ]
      },
      {
        "name": "RegionalDifficulty",
        "source": "regional_difficulty_multipliers",
        "primary_key": "region",
        "columns": [
          {"name": "region", "type": "Text"},
          {"name": "country", "type": "Text"},
          {"name": "multiplier", "type": "Number"},
          {"name": "server_competitiveness", "type": "Number"}
        ]
      },
      {
        "name": "CalculatedScores",
        "source": "DAX Calculated Table",
        "relationships": [
          {"from": "Players[region]", "to": "RegionalDifficulty[region]"},
          {"from": "Players[player_id]", "to": "MechanicalSkills[player_id]"}
        ],
        "calculated_columns": [
          {
            "name": "adjusted_global_score",
            "formula": "MechanicalSkills[weighted_average] * RegionalDifficulty[multiplier] / 1.20 * 100"
          },
          {
            "name": "weighted_skill_average",
            "formula": "SUMX(MechanicalSkills, [dimension_value] * [dimension_weight])"
          }
        ]
      }
    ]
  },
  "power_bi_visualizations": {
    "description": "Recommended visualizations for GameRadar AI dashboard",
    "visuals": [
      {
        "id": "spider_chart_comparison",
        "type": "Radar Chart (Spider Chart)",
        "title": "Mechanical Skill Vector: Amateur vs Pro",
        "data_source": "MechanicalSkills",
        "axes": [
          "micro_mechanics",
          "macro_awareness",
          "consistency",
          "adaptability",
          "team_synergy",
          "mechanical_ceiling"
        ],
        "legend": {
          "amateur": "Players[is_professional] = FALSE",
          "professional": "Players[is_professional] = TRUE"
        },
        "filters": [
          "Players[region]",
          "Players[rank]",
          "Players[player_archetype]"
        ],
        "color_scheme": "#FF6B6B (Amateur), #1DD1A1 (Pro)"
      },
      {
        "id": "regional_ranking_scatter",
        "type": "Scatter Chart",
        "title": "Regional Difficulty-Adjusted Global Ranking",
        "x_axis": "CalculatedScores[adjusted_global_score]",
        "y_axis": "RegionalDifficulty[multiplier]",
        "size": "MechanicalSkills[mechanical_ceiling]",
        "color": "Players[region]",
        "filters": [
          "Players[is_professional]",
          "Players[rank]"
        ]
      },
      {
        "id": "archetype_distribution",
        "type": "Donut Chart",
        "title": "Player Archetype Distribution by Region",
        "values": "COUNT(Players[player_id])",
        "legend": "Players[player_archetype]",
        "filters": ["Players[region]"]
      },
      {
        "id": "top_prospects_table",
        "type": "Table with Conditional Formatting",
        "title": "Top 50 Amateur Prospects (Difficulty-Adjusted)",
        "columns": [
          "Players[nickname]",
          "Players[region]",
          "Players[rank]",
          "CalculatedScores[adjusted_global_score]",
          "Players[player_archetype]",
          "MechanicalSkills[mechanical_ceiling]"
        ],
        "sort_by": "CalculatedScores[adjusted_global_score] DESC",
        "filters": ["Players[is_professional] = FALSE"],
        "conditional_formatting": {
          "adjusted_global_score": {
            ">90": "#1DD1A1",
            "80-90": "#4ECDC4",
            "70-80": "#FFE66D",
            "<70": "#FF6B6B"
          }
        }
      },
      {
        "id": "regional_competitiveness_map",
        "type": "Map Visual",
        "title": "Server Competitiveness Heatmap",
        "location": "RegionalDifficulty[country]",
        "size": "RegionalDifficulty[server_competitiveness]",
        "color": "RegionalDifficulty[multiplier]"
      }
    ]
  },
  "power_bi_filters": {
    "description": "Recommended slicer filters for interactive dashboard",
    "slicers": [
      {
        "name": "Region Filter",
        "source": "Players[region]",
        "type": "Dropdown Multi-Select",
        "default": ["KR", "CN", "IN", "VN"]
      },
      {
        "name": "Professional Status",
        "source": "Players[is_professional]",
        "type": "Toggle",
        "options": ["Amateur Only", "Professional Only", "Both"]
      },
      {
        "name": "Rank Tier",
        "source": "Players[rank]",
        "type": "Checkbox",
        "hierarchy": ["challenger", "grandmaster", "master", "diamond"]
      },
      {
        "name": "Archetype Filter",
        "source": "Players[player_archetype]",
        "type": "Button Grid",
        "visual_style": "Icon + Label"
      },
      {
        "name": "Skill Threshold",
        "source": "CalculatedScores[adjusted_global_score]",
        "type": "Range Slider",
        "min": 0,
        "max": 100,
        "default": [70, 100]
      }
    ]
  },
  "dax_formulas": {
    "description": "DAX formulas for calculated measures in Power BI",
    "measures": [
      {
        "name": "Weighted Skill Average",
        "formula": "SUMX(\n    MechanicalSkills,\n    [micro_mechanics] * 0.20 +\n    [macro_awareness] * 0.18 +\n    [consistency] * 0.15 +\n    [adaptability] * 0.12 +\n    [team_synergy] * 0.15 +\n    [mechanical_ceiling] * 0.20\n)"
      },
      {
        "name": "Adjusted Global Score",
        "formula": "DIVIDE(\n    [Weighted Skill Average] * RELATED(RegionalDifficulty[multiplier]),\n    1.20\n) * 100"
      },
      {
        "name": "Amateur vs Pro Avg Delta",
        "formula": "VAR AmateurAvg = CALCULATE([Weighted Skill Average], Players[is_professional] = FALSE)\nVAR ProAvg = CALCULATE([Weighted Skill Average], Players[is_professional] = TRUE)\nRETURN AmateurAvg - ProAvg"
      },
      {
        "name": "Regional Talent Density",
        "formula": "COUNTROWS(\n    FILTER(\n        Players,\n        [adjusted_global_score] >= 80\n    )\n) / COUNTROWS(Players)"
      },
      {
        "name": "Top 10% Threshold",
        "formula": "PERCENTILE.INC(\n    CalculatedScores[adjusted_global_score],\n    0.90\n)"
      }
    ]
  },
