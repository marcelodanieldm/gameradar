  "player_archetypes": {
    "description": "Classification system for prospect categorization in Power BI dashboards",
    "archetypes": [
      {
        "id": "mechanical_prodigy",
        "name": "Mechanical Prodigy",
        "profile": {
          "micro_mechanics": ">85",
          "mechanical_ceiling": ">90",
          "consistency": "<70",
          "team_synergy": "<65"
        },
        "typical_regions": ["KR", "CN"],
