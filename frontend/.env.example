# ====================================
# GameRadar - Supabase Configuration
# ====================================

# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a .env.local
# 2. Ve a https://app.supabase.com
# 3. Abre tu proyecto GameRadar
# 4. Ve a Settings → API
# 5. Copia los valores reales y reemplázalos aquí

# ====================================
# Supabase (REQUERIDO)
# ====================================

# Project URL - Obtener de: Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here

# Anon/Public Key - Obtener de: Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service Role Key (SECRETO - solo server-side)
# Obtener de: Settings → API → Project API keys → service_role secret
# ⚠️ NUNCA compartir esta clave públicamente
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ====================================
# OpenAI (para semantic search embeddings)
# ====================================

# OpenAI API Key - Obtener de: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ====================================
# Backend API
# ====================================

# URL del backend FastAPI (localhost en desarrollo)
BACKEND_URL=http://localhost:8000

# ====================================
# Environment
# ====================================

# Modo de desarrollo
NODE_ENV=development

# ====================================
# VERIFICACIÓN
# ====================================
# Una vez configurado:
# 1. Verifica que .env.local esté en la raíz de /frontend
# 2. Reinicia el servidor de desarrollo: npm run dev
# 3. Verifica en la consola que no haya errores de Supabase

